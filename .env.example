# Copy to .env on PiSensors and fill in real values. Never commit .env.

# MariaDB (homedata on PiSensors)
DB_HOST=localhost
DB_USER=hu
DB_PASSWORD=your_password_here
DB_NAME=homedata

# FastAPI (test port before nginx cutover)
API_HOST=0.0.0.0
API_PORT=8090

# Collector log (served by GET /api/v1/logs/collect)
COLLECTOR_LOG_PATH=/home/pi/HomeData/Logs/collect_data.log
